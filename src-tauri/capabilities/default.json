{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for all windows",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:window:allow-destroy",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "screenshots:default",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-image",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" }
      ]
    }
  ]
}
