{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-destroy",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" }
      ]
    }
  ]
}
