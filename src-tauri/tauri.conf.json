{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tether",
  "version": "0.0.1",
  "identifier": "co.paracord.tether",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tether",
        "width": 1920,
        "height": 1080,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "engine_server.py",
      "engine_pyproject.toml",
      "target/release/tether-cli"
    ]
  }
}
